# ─── Copy this file to .env and fill in the values ───────────────────────────
# cp .env.example .env
#
# .env is listed in .gitignore — never commit real secrets.

# ── Required ──────────────────────────────────────────────────────────────────

# Your Anthropic API key — get one at https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# Secret used to authenticate API requests (X-API-Key header)
API_KEY=change-me-before-deploying

# ── Neo4j (only needed when running outside Docker) ───────────────────────────
# Inside Docker these are set directly in docker-compose.yml.

NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=supplychainkg
NEO4J_DATABASE=neo4j

# ── Optional overrides ────────────────────────────────────────────────────────

# Claude model to use for entity extraction
# CLAUDE_MODEL=claude-sonnet-4-6

# API server settings (only relevant outside Docker)
# API_HOST=0.0.0.0
# API_PORT=8000
# API_LOG_LEVEL=info

# Log format: json (production) or text (development)
# LOG_FORMAT=json
# LOG_LEVEL=INFO

# Application
# APP_NAME=Supply Chain Knowledge Graph
# APP_VERSION=0.1.0
# DEBUG=false
